ing Common.Geometry;\r\nusing Common;\r\nusing Script;\r\nusing System.Collections.Concurrent;\r\nusing System.Collections.Generic;\r\nusing System.Diagnostics;\r\nusing System;\r\nusing System.IO;\r\nusing System.Linq;\r\n\r\nnamespace Plugin.ScriptCSharp\r\n{\r\n    /// <summary>\r\n    /// и„ҡжң¬еҠҹиғҪпјҡе°ҶеҠ е·Ҙеқҗж ҮиЎЁиҪ¬жҚўдёәдёүиҪҙXгҖҒYеқҗж ҮеҲ—иЎЁпјҢз”ЁдәҺPLCеҶҷе…Ҙ\r\n    /// е®һзҺ°IScriptжҺҘеҸЈпјҢжү§иЎҢеҸӮж•°еӨ„зҗҶгҖҒеқҗж Үж ЎйӘҢгҖҒж•°жҚ®иҪ¬жҚў\r\n    /// </summary>\r\n    public class ScriptToXYList : IScript\r\n    {\r\n        /// <summary>\r\n        /// и„ҡжң¬жү§иЎҢе…ҘеҸЈ\r\n        /// </summary>\r\n        /// <param name=\"parameters\">дј е…Ҙзҡ„еҸӮж•°еӯ—е…ё</param>\r\n        /// <returns>жү§иЎҢз»“жһңеӯ—е…ё</returns>\r\n        public ConcurrentDictionary<string, object> Execute(ConcurrentDictionary<string, object> parameters)\r\n        {\r\n            // еҲқе§ӢеҢ–иҝ”еӣһз»“жһңеӯ—е…ё\r\n            ConcurrentDictionary<string, object> result = new ConcurrentDictionary<string, object>();\r\n\r\n            // д»Һдј е…ҘеҸӮж•°дёӯиҺ·еҸ–еҗ„зұ»еқҗж ҮиЎЁж•°жҚ®\r\n            var szdit = parameters[\"еҶҷдёүиҪҙеқҗж Ү.еҠ е·Ҙеқҗж ҮиЎЁ\"] as Dictionary<string, Point>;  // еҠ е·Ҙеқҗж ҮиЎЁ\r\n            var qxxtdit = parameters[\"е…ЁеұҖ.ж ҮеҮҶMarkзӮ№еқҗж ҮиЎЁ\"] as Dictionary<string, Point>; // ж ҮеҮҶMarkзӮ№еқҗж ҮиЎЁ\r\n            var xtdit = parameters[\"е…ЁеұҖ.е®ҡдҪҚMarkзӮ№еқҗж ҮиЎЁ\"] as Dictionary<string, Point>;   // е®ҡдҪҚMarkзӮ№еқҗж ҮиЎЁ\r\n            var jgpc = (double)parameters[\"е…ЁеұҖ.MarkзӮ№й—ҙи·қеҒҸе·®\"];                           // MarkзӮ№й—ҙи·қе…Ғи®ёеҒҸе·®еҖј\r\n\r\n            // иҺ·еҸ–еҠ е·ҘзӮ№жҖ»ж•°\r\n            int cellnum = (int)parameters[\"е…ЁеұҖ.еҠ е·ҘзӮ№ж•°\"];\r\n\r\n            short i = 0;          // PLCеҶҷе…Ҙз»“жһңж ҮиҜҶ\r\n            bool b = false;       // ж•ҙдҪ“иҝҗиЎҢз»“жһңж ҮиҜҶ\r\n\r\n            // з¬¬дёҖжӯҘпјҡж ЎйӘҢжүҖжңүеҝ…иҰҒеҸӮж•°жҳҜеҗҰдёәз©әгҖҒеҠ е·ҘзӮ№ж•°жҳҜеҗҰжңүж•Ҳ\r\n            if (!szdit.IsNullOrEmpty() && !qxxtdit.IsNullOrEmpty() && !xtdit.IsNullOrEmpty() && cellnum != 0)\r\n            {\r\n                // з¬¬дәҢжӯҘпјҡж ЎйӘҢж ҮеҮҶMarkзӮ№е’Ңе®ҡдҪҚMarkзӮ№ж•°йҮҸеҝ…йЎ»йғҪжҳҜ3дёӘ\r\n                if (qxxtdit.Count == 3 && xtdit.Count == 3)\r\n                {\r\n                    // и®Ўз®—ж ҮеҮҶMarkзӮ№дёӨдёӨд№Ӣй—ҙзҡ„и·қзҰ»\r\n                    var qxjg1 = Point.CalculateDistance(qxxtdit[\"1\"], qxxtdit[\"2\"]);\r\n                    var qxjg2 = Point.CalculateDistance(qxxtdit[\"2\"], qxxtdit[\"3\"]);\r\n                    var qxjg3 = Point.CalculateDistance(qxxtdit[\"1\"], qxxtdit[\"3\"]);\r\n\r\n                    // и®Ўз®—е®ҡдҪҚMarkзӮ№дёӨдёӨд№Ӣй—ҙзҡ„и·қзҰ»\r\n                    var xtjg1 = Point.CalculateDistance(xtdit[\"1\"], xtdit[\"2\"]);\r\n                    var xtjg2 = Point.CalculateDistance(xtdit[\"2\"], xtdit[\"3\"]);\r\n                    var xtjg3 = Point.CalculateDistance(xtdit[\"1\"], xtdit[\"3\"]);\r\n\r\n                    // и®Ўз®—дёӨз»„MarkзӮ№еҜ№еә”й—ҙи·қзҡ„е·®еҖј\r\n                    var cz1 = Math.Abs(qxjg1 - xtjg1);\r\n                    var cz2 = Math.Abs(qxjg2 - xtjg2);\r\n                    var cz3 = Math.Abs(qxjg3 - xtjg3);\r\n\r\n                    // з¬¬дёүжӯҘпјҡж ЎйӘҢй—ҙи·қеҒҸе·®жҳҜеҗҰеңЁе…Ғи®ёиҢғеӣҙеҶ…\r\n                    if (cz1 <= jgpc && cz2 <= jgpc && cz3 <= jgpc)\r\n                    {\r\n                        // з¬¬еӣӣжӯҘпјҡж ЎйӘҢеҠ е·Ҙеқҗж ҮиЎЁж•°йҮҸдёҺи®ҫе®ҡеҠ е·ҘзӮ№ж•°дёҖиҮҙ\r\n                        if (szdit.Count == cellnum)\r\n                        {\r\n                            // е®ҡд№үXгҖҒYеқҗж ҮеҲ—иЎЁпјҢз”ЁдәҺеӯҳеӮЁиҪ¬жҚўеҗҺзҡ„еқҗж Ү\r\n                            List<int> xs = new List<int>();\r\n                            List<int> ys = new List<int>();\r\n                            bool fb = true; // еқҗж ҮйҒҚеҺҶиҪ¬жҚўз»“жһңж ҮиҜҶ\r\n\r\n                            // йҒҚеҺҶжүҖжңүеҠ е·ҘзӮ№пјҢиҪ¬жҚўеқҗж Ү\r\n                            for (int j = 1; j <= cellnum; j++)\r\n                            {\r\n                                string key = j.ToString();\r\n                                // ж ЎйӘҢеқҗж ҮиЎЁжҳҜеҗҰеҢ…еҗ«еҪ“еүҚеәҸеҸ·\r\n                                if (szdit.ContainsKey(key))\r\n                                {\r\n                                    // Xеқҗж Үж”ҫеӨ§80еҖҚиҪ¬intпјҢYеқҗж Үж”ҫеӨ§100еҖҚиҪ¬int\r\n                                    xs.Add((szdit[key].X * 80).To<int>());\r\n                                    ys.Add((szdit[key].Y * 100).To<int>());\r\n                                }\r\n                                else\r\n                                {\r\n                                    // зјәе°‘еҜ№еә”еәҸеҸ·еқҗж ҮпјҢи®°еҪ•й”ҷиҜҜдҝЎжҒҜ\r\n                                    result.TryAdd(\"иҝ”еӣһж¶ҲжҒҜ\", $\"е…ЁеұҖ.з„ҠжҺҘеқҗж ҮиЎЁеӯ—е…ёдёӯдёҚеҢ…еҗ«еәҸеҸ·{key}\");\r\n                                    fb = false;\r\n                                    break;\r\n                                }\r\n                            }\r\n\r\n                            // жүҖжңүеқҗж ҮиҪ¬жҚўжҲҗеҠҹпјҢеӯҳе…Ҙиҝ”еӣһз»“жһң\r\n                            if (fb)\r\n                            {\r\n                                result.TryAdd(\"еҶҷдёүиҪҙеқҗж Ү.дёүиҪҙXз»„\", xs);\r\n                                result.TryAdd(\"еҶҷдёүиҪҙеқҗж Ү.дёүиҪҙYз»„\", ys);\r\n                                b = true;\r\n                            }\r\n\r\n                        }\r\n                        else\r\n                        {\r\n                            // еҠ е·Ҙеқҗж Үж•°йҮҸдёҚеҢ№й…Қй”ҷиҜҜ\r\n                            result.TryAdd(\"иҝ”еӣһж¶ҲжҒҜ\", $\"еҶҷдёүиҪҙеқҗж Ү.еҠ е·Ҙеқҗж ҮиЎЁзҡ„й•ҝеәҰдёҚзӯүдәҺ{cellnum}:{szdit.Count}\");\r\n                        }\r\n                    }\r\n                    else\r\n                    {\r\n                        // MarkзӮ№й—ҙи·қеҒҸе·®и¶…йҷҗй”ҷиҜҜ\r\n                        result.TryAdd(\"иҝ”еӣһж¶ҲжҒҜ\", $\"еҪ“еүҚMarkзӮ№еҜ№жҜ”ж ҮеҮҶMarkзӮ№й—ҙи·қеӨ§дәҺи®ҫе®ҡеҖј[{jgpc}]:{cz1}гҖҒ{cz2}гҖҒ{cz3}\");\r\n                    }\r\n\r\n                }\r\n                else\r\n                {\r\n                    // MarkзӮ№ж•°йҮҸдёҚжҳҜ3дёӘй”ҷиҜҜ\r\n                    result.TryAdd(\"иҝ”еӣһж¶ҲжҒҜ\", $\"е…ЁеұҖ.ж ҮеҮҶMarkеқҗж ҮиЎЁжҲ–е…ЁеұҖ.е®ҡдҪҚMarkиЎЁйӣҶеҗҲзҡ„ж•°йҮҸдёҚдёә3:[{qxxtdit.Count}]гҖҒ[{xtdit.Count}]\");\r\n                }\r\n            }\r\n            else\r\n            {\r\n                // еҸӮж•°дёәз©әжҲ–ж— ж•Ҳй”ҷиҜҜпјҢиҫ“еҮәеҸӮж•°иҜҰжғ…\r\n                string retMsg = parameters.ConvertToString();\r\n                result.TryAdd(\"иҝ”еӣһж¶ҲжҒҜ\", $\"иҪ¬жҚўеҖјй”ҷиҜҜ:{retMsg}\");\r\n            }\r\n\r\n            // ж №жҚ®иҝҗиЎҢз»“жһңи®ҫзҪ®PLCеҶҷе…Ҙж ҮиҜҶпјҡ1=жҲҗеҠҹпјҢ2=еӨұиҙҘ\r\n            i = (short)(b ? 1 : 2);\r\n            result.TryAdd(\"еҶҷдёүиҪҙеқҗж Ү.PLCеҶҷе…Ҙз»“жһң\", i);\r\n            result.TryAdd(\"иҝҗиЎҢз»“жһң\", b);\r\n\r\n            // иҝ”еӣһжңҖз»Ҳжү§иЎҢз»“жһң\r\n            return result;\r\n        }\r\n    }\r\n}","Name":"и„ҡжң¬1","ReferenceFilesCustom":{"$type":"System.Collections.ObjectModel.ObservableCollection`1[[System.String, System.Private.CoreLib]], System.ObjectModel","$values":[]}},"IsExitChild":false,"Children":null,"Name":"еқҗж Үи§Јжһҗ","Enble":true,"ExceptionHanding":0,"GotoTool":{"$type":"System.Windows.Core.LinkParameter`1[[Tool.ToolBase, Tool]], System.Windows.Core","Name":null,"Link":"","Description":null},"IsShowResultLay":false,"Hierarchy":0},{"$type":"Plugin.ControlDevice.ToolControlDevice, Plugin.ControlDevice","Device":{"$type":"System.Windows.Core.LinkParameter`1[[Device.DeviceBase, Device]], System.Windows.Core","Name":null,"Link":"е…ЁеұҖ.PLC","Description":null},"Functions":{"$type":"System.Collections.ObjectModel.ObservableCollection`1[[System.Windows.Core.FunctionInfo, System.Windows.Core]], System.ObjectModel","$values":[{"$type":"System.Windows.Core.FunctionInfo, System.Windows.Core","Enable":true,"Name":"WriteInt","DisplayName":"жү№йҮҸеҶҷ32дҪҚең