ssEvent, Common]], System.Windows.Core","Name":null,"Link":"е…ЁеұҖ.жү«з ҒеҷЁ","Description":null},"Events":{"$type":"System.Collections.ObjectModel.ObservableCollection`1[[Common.ProcessEventInfo, Common]], System.ObjectModel","$values":[{"$type":"Common.ProcessEventInfo, Common","Name":"е…ЁеұҖ.жү«з ҒеҷЁ","TrigType":32,"TrigMessageRegular":null}]},"StartCondition":null},"ContainerVariable":{"$type":"Common.ContainerVariable, Common","Name":"жү«з Ғ","Variables":{"$type":"System.Collections.ObjectModel.ObservableCollection`1[[Common.VariableInfo, Common]], System.ObjectModel","$values":[{"$type":"Common.VariableInfo, Common","IsLock":false,"Name":"еҶҷе…Ҙз»“жһң","Type":"System.Int16, System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e","TypeFullName":"System.Int16","Value":2,"IsCustom":true,"Description":null}]}}},{"$type":"Core.TaskFlow, Core","Tools":{"$type":"System.Collections.ObjectModel.ObservableCollection`1[[Tool.ToolBase, Tool]], System.ObjectModel","$values":[{"$type":"Plugin.ScriptCSharp.ToolScriptCSharp, Plugin.ScriptCSharp","Scripter":{"$type":"Script.ScripterCSharp, Script","ScriptCode":"using Common.Geometry;\r\nusing Script;\r\nusing System.Collections.Concurrent;\r\nusing System.Collections.Generic;\r\nusing System.Diagnostics;\r\nusing System;\r\nusing System.IO;\r\nusing System.Linq;\r\n\r\nnamespace Plugin.ScriptCSharp\r\n{\r\n    public class ReadData : IScript\r\n    {\r\n        public ConcurrentDictionary<string, object> Execute(ConcurrentDictionary<string, object> parameters)\r\n        {\r\n            ConcurrentDictionary<string, object> result = new ConcurrentDictionary<string, object>();\r\n            var path =(string) parameters[\"дёҠдј MES.ж•°жҚ®ж–Үд»¶и·Ҝеҫ„\"];\r\n            if (!path.IsNullOrEmpty())\r\n            {\r\n                if (File.Exists(path))\r\n                {\r\n                    var power= XMLProcess.Read(path, \"/Datas/жңҖеӨ§еҠҹзҺҮ\").To<double>();\r\n                    result.TryAdd(\"дёҠдј MES.жҝҖе…үеҠҹзҺҮ\", power);\r\n                    result.TryAdd(\"иҝҗиЎҢз»“жһң\", true);\r\n                }\r\n                else\r\n                {\r\n                    result.TryAdd(\"иҝ”еӣһж¶ҲжҒҜ\", $\"ж–Үд»¶[{path}]дёҚеӯҳеңЁ!\");\r\n                }\r\n            }\r\n            else\r\n            {\r\n                string retMsg = parameters.Select(s => $\"{s.Key}:{s.Value}\").ToStringJoin(\";\");\r\n                result.TryAdd(\"иҝ”еӣһж¶ҲжҒҜ\", $\"иҫ“е…ҘеҸӮж•°иҪ¬жҚўй”ҷиҜҜ:{retMsg}\");\r\n            }\r\n            result.TryAdd(\"иҝҗиЎҢз»“жһң\", false);\r\n            return result;\r\n        }\r\n    }\r\n}","Name":"и„ҡжң¬1","ReferenceFilesCustom":{"$type":"System.Collections.ObjectModel.ObservableCollection`1[[System.String, System.Private.CoreLib]], System.ObjectModel","$values":[]}},"IsExitChild":false,"Children":null,"Name":"иҜ»еҸ–жҝҖе…үеҸӮж•°","Enble":false,"ExceptionHanding":0,"GotoTool":{"$type":"System.Windows.Core.LinkParameter`1[[Tool.ToolBase, Tool]], System.Windows.Core","Name":null,"Link":"","Description":null},"IsShowResultLay":false,"Hierarchy":0},{"$type":"Plugin.ScriptCSharp.ToolScriptCSharp, Plugin.ScriptCSharp","Scripter":{"$type":"Script.ScripterCSharp, Script","ScriptCode":"using Common.Geometry;\r\nusing Script;\r\nusing System.Collections.Concurrent;\r\nusing System.Collections.Generic;\r\nusing System.Diagnostics;\r\nusing System;\r\nusing System.IO;\r\nusing System.Linq;\r\n\r\nnamespace Plugin.ScriptCSharp\r\n{\r\n    public class Script2PointSlopeComparison : IScript\r\n    {\r\n        public ConcurrentDictionary<string, object> Execute(ConcurrentDictionary<string, object> parameters)\r\n        {\r\n            ConcurrentDictionary<string, object> result = new ConcurrentDictionary<string, object>();\r\n            var dwdit = parameters[\"е…ЁеұҖ.е®ҡдҪҚеқҗж Ү\"] as Dictionary<string, Point>;\r\n            var jdzdpc = parameters[\"е…ЁеұҖ.жһҒжҹұи§’еәҰжңҖеӨ§еҒҸе·®\"].ToString().To<double>();\r\n            bool b = false;\r\n            List<double> slopes = new List<double>();\r\n            if (dwdit.IsNotNullOrEmpty() && jdzdpc != 0)\r\n            {\r\n                var no = dwdit.Keys.ToArray()[dwdit.Count - 1].To<int>();\r\n                if (no % 2 == 0)\r\n                {\r\n                    for (int i = 0; i < no / 2; i++)\r\n                    {\r\n                        double sp = 0;\r\n                        sp = Point.Get2PointAngle(dwdit[(i * 2 + 1).ToString()], dwdit[(i * 2 + 2).ToString()]);\r\n                        sp = Math.Abs(sp);\r\n                        slopes.Add(sp);\r\n                    }\r\n                    var ms = slopes.GetMidItems(1, 1);\r\n                    var avg = ms.Average();\r\n                    var min = slopes.Min();\r\n                    var max = slopes.Max();\r\n                    if ((max - avg) > jdzdpc)\r\n                    {\r\n                        result.TryAdd(\"иҝ”еӣһж¶ҲжҒҜ\", $\"з”өиҠҜ[{slopes.IndexOf(max) + 1}]жһҒжҹұе®ҡдҪҚи§’еәҰ[{max}]зӣёе·®е№іеқҮеҖј[{avg}]{max - avg}еәҰ,и¶…еҮәе…ЁеұҖ.жһҒжҹұи§’еәҰжңҖеӨ§еҒҸе·®[{jdzdpc}]йҷҗеҲ¶пјҢжүҖжңүз”өиҠҜжһҒжҹұе®ҡдҪҚи§’еәҰ:{slopes.ConvertToString()}\");\r\n                    }\r\n                    else if ((avg - min) > jdzdpc)\r\n                    {\r\n                        result.TryAdd(\"иҝ”еӣһж¶ҲжҒҜ\", $\"з”өиҠҜ[{slopes.IndexOf(min) + 1}]жһҒжҹұе®ҡдҪҚи§’еәҰ[{min}]зӣёе·®е№іеқҮеҖј[{avg}]{avg - min}еәҰ,и¶…еҮәе…ЁеұҖ.жһҒжҹұи§’еәҰжңҖеӨ§еҒҸе·®[{jdzdpc}]йҷҗеҲ¶пјҢжүҖжңүз”өиҠҜжһҒжҹұе®ҡдҪҚи§’еәҰ:{slopes.ConvertToString()}\");\r\n                    }\r\n                    else\r\n                    {\r\n                        result.TryAdd(\"иҝ”еӣһж¶ҲжҒҜ\", $\"жүҖжңүз”өиҠҜжһҒжҹұе®ҡдҪҚи§’еәҰ:{slopes.ConvertToString()}\");\r\n                        b = true;\r\n                    }\r\n                }\r\n            }\r\n            else\r\n            {\r\n                string retMsg = parameters.ConvertToString();\r\n                result.TryAdd(\"иҝ”еӣһж¶ҲжҒҜ\", $\"иҪ¬жҚўеҖјй”ҷиҜҜ:{retMsg}\");\r\n            }\r\n            result.TryAdd(\"иҝҗиЎҢз»“жһң\", b);\r\n            return result;\r\n        }\r\n    }\r\n}","Name":"и„ҡжң¬1","ReferenceFilesCustom":{"$type":"System.Collections.ObjectModel.ObservableCollection`1[[System.String, System.Private.CoreLib]], System.ObjectModel","$values":[]}},"IsExitChild":false,"Children":null,"Name":"еҲӨж–ӯжһҒжҹұи§’еәҰ","Enble":false,"ExceptionHanding":0,"GotoTool":{"$type":"System.Windows.Core.LinkParameter`1[[Tool.ToolBase, Tool]], System.Windows.Core","Name":null,"Link":null,"Description":null},"IsShowResultLay":false,"Hierarchy":0},{"$type":"Plugin.WriteCsv.ToolWriteCsv, Plugin.WriteCsv","IsDateSuffix":true,"FileName":"дә§е“Ғж•°жҚ®","Folder":"D:\\жё…жҙ—жңәи§Ҷи§ү\\Data","CsvInfos":{"$type":"System.Collections.ObjectModel.ObservableCollection`1[[Plugin.WriteCsv.CsvInfo, Plugin.WriteCsv]], System.ObjectModel","$values":[{"$type":"Plugin.WriteCsv.CsvInfo, Plugin.WriteCsv","Name":"жқЎз Ғ","Link":"е…ЁеұҖ.жқЎз Ғ","Value":"HVB 1000V-2403-00002","VariableInfo":{"$type":"Common.VariableInfo, Common","IsLock":false,"Name":"еҸҳйҮҸ33","Type":"System.String, System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e","TypeFullName":"System.String","Value":"HVB 1000V-2403-00002","IsCustom":true,"Description":null}},{"$type":"Plugin.WriteCsv.CsvInfo, Plugin.WriteCsv","Name":"жҝҖе…үеҠҹзҺҮ","Link":"дёҠдј MES.жҝҖе…үеҠҹзҺҮ","Value":"1105.96","VariableInfo":{"$type":"Common.VariableInfo, Common","IsLock":false,"Name":"еҸҳйҮҸ87","Type":"System.String, System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e","TypeFullName":"System.String","Value":"1105.96","IsCustom":true,"Description":null}}]},"Links":{"$type":"System.Collections.Generic.Dictionary`2+KeyCollection[[System.String, System.Private.CoreLib],[System.String, System.Private.CoreLib]], System.Private.CoreLib","$values":["иҜ»еҸ–жҝҖе…үеҸӮж•°.е·Ҙе…·зҠ